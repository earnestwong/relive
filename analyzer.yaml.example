# relive-analyzer 离线分析工具配置示例
# 使用方法：
# 1. 复制此文件：cp analyzer.yaml.example analyzer.yaml
# 2. 修改配置（特别是 endpoint 和 api_key）
# 3. 运行：./backend/bin/relive-analyzer check -config analyzer.yaml

server:
  endpoint: "http://localhost:8080"     # Relive 服务端地址
  api_key: "${RELIVE_API_KEY}"          # API Key（建议从环境变量读取）
  timeout: 30                           # API 请求超时（秒）

analyzer:
  workers: 4                            # 并发分析数（根据 AI 提供商标配）
  fetch_limit: 10                       # 每批获取任务数
  retry_count: 3                        # AI 分析重试次数
  retry_delay: 5                        # 重试延迟（秒）
  checkpoint_file: "./data/analyzer-checkpoint.db"  # 断点续传文件路径（项目内独立文件，避免不同目录共享）

ai:
  provider: "ollama"                    # AI Provider: ollama, vllm
  ollama:
    endpoint: "http://localhost:11434"
    model: "llava:13b"
    temperature: 0.7
    timeout: 120
  vllm:
    endpoint: "http://localhost:8000"
    model: "llava-v1.6-vicuna-13b"
    temperature: 0.7
    timeout: 120

download:
  temp_dir: "./data/relive-analyzer/temp"   # 临时文件目录
  timeout: 60                           # 下载超时（秒）
  max_concurrent: 5                     # 最大并发下载
  retry_count: 3                        # 下载重试次数
  keep_temp: false                      # 是否保留临时文件（调试用）

batch:
  size: 10                              # 批量提交数量
  flush_interval: 30                    # 自动刷新间隔（秒）
  max_retry: 3                          # 提交失败重试次数
  retry_delay: 5                        # 重试延迟（秒）

logging:
  level: "info"                         # 日志级别: debug, info, warn, error
  console: true                         # 输出到控制台
  file: "../data/analyzer.log"                  # 日志文件路径（相对路径或绝对路径）
